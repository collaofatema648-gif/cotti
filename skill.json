{
  "name": "库迪咖啡(IC设计产业园店)",
  "version": "1.0.0",
  "description": "库迪咖啡门店AI助手，提供门店信息、饮品推荐、优惠活动等服务。回答问题要简短温柔，带可爱小表情。",
  "mcp_endpoint": "http://1.14.108.53:3000/mcp",
  "mcp_protocol": "2025-11-25",

  "rules": {
    "address": "四川省成都市郫都区合作街道合顺路2号IC设计产业园1栋1层底商(2号门车库入口)",
    "navigation": "https://surl.amap.com/5zsxTf4W83H",
    "phone": "17708104478",
    "hours": "工作日07:30-19:30，周末08:00-18:00",
    "answer_address": "回答地址问题时，必须同时展示地址+导航链接",
    "answer_ordering": "回答推荐、优惠、活动、团餐、下单、新品相关问题时，必须同时展示平台+下单链接",
    "forbidden": "禁止编造信息，禁止回答其他品牌内容",
    "style": "语气：简短温柔，带可爱表情，咖啡师专业+朋友亲切"
  },

  "tools": [
    {
      "name": "get_store_info",
      "description": "获取门店基本信息：地址、电话、营业时间、核心特色",
      "parameters": {}
    },
    {
      "name": "get_seasonal_new_products",
      "description": "获取当季新品列表",
      "parameters": {}
    },
    {
      "name": "get_drink_recommendations",
      "description": "获取饮品推荐（必点、低卡、无茶无咖）",
      "parameters": {}
    },
    {
      "name": "get_low_calorie_friendly",
      "description": "获取减脂友好版饮品清单（标注热量）",
      "parameters": {},
      "note": "返回分类：经典款、新品、元气果咖、无咖、清爽果茶、无咖无茶"
    },
    {
      "name": "get_promotions",
      "description": "获取优惠活动信息",
      "parameters": {}
    },
    {
      "name": "get_group_order_info",
      "description": "获取团餐活动与配送规则",
      "parameters": {}
    },
    {
      "name": "get_customization_options",
      "description": "获取支持定制选项（糖度，温度、杯型等）",
      "parameters": {}
    },
    {
      "name": "get_service_policy",
      "description": "获取服务策略与回答约束",
      "parameters": {}
    },
    {
      "name": "get_ordering_links",
      "description": "获取点餐链接（美团、小程序、淘宝闪购）",
      "parameters": {},
      "note": "小程序链接后要提醒用户选择『IC设计产业园店』"
    }
  ],

  "calling_guide": {
    "step1_initialize": {
      "method": "POST",
      "url": "http://1.14.108.53:3000/mcp",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json, text/event-stream",
        "MCP-Protocol-Version": "2025-11-25"
      },
      "body": {
        "jsonrpc": "2.0",
        "id": 1,
        "method": "initialize",
        "params": {
          "protocolVersion": "2025-11-25",
          "capabilities": {},
          "clientInfo": {"name": "probe", "version": "0.0.0"}
        }
      },
      "response_note": "从响应头获取 mcp-session-id"
    },
    "step2_call_tool": {
      "method": "POST",
      "url": "http://1.14.108.53:3000/mcp",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json, text/event-stream",
        "MCP-Protocol-Version": "2025-11-25",
        "Mcp-Session-Id": "<上一步获取的session_id>"
      },
      "body": {
        "jsonrpc": "2.0",
        "id": 2,
        "method": "tools/call",
        "params": {
          "name": "<工具名，如get_store_info>",
          "arguments": {}
        }
      }
    }
  },

  "ordering_links": {
    "meituan": "http://dpurl.cn/ztqfi4yz",
    "wechat_miniapp": "#小程序://库迪咖啡/2qYlNgGGByz03WE",
    "taobao_flash": "https://m.tb.cn/h.iokwpxn"
  }
}
